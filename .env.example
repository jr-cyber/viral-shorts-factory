# Clip App API (for AI clipping)
CLIP_API_URL=https://api.clipapp.io
CLIP_API_KEY=your_clip_api_key

# Potato Scheduler (TikTok/Social posting)
POTATO_API_URL=https://api.potato.tools
POTATO_API_KEY=your_potato_api_key

# Publer (Alternative scheduler)
PUBLER_API_URL=https://publer.io/api/v1
PUBLER_API_KEY=your_publer_api_key

# Blotato (Alternative scheduler)
BLOTATO_API_URL=https://api.blotato.com/v1
BLOTATO_API_KEY=your_blotato_api_key

# TikTok API
TIKTOK_CLIENT_KEY=your_tiktok_client_key
TIKTOK_CLIENT_SECRET=your_tiktok_client_secret
TIKTOK_REDIRECT_URI=http://localhost:3000/api/tiktok/callback